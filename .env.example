# .env.example — EM Dashboard MetLife BR Life
# Copie este arquivo para .env e preencha com seus tokens reais:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)
#
# NUNCA commite o arquivo .env — ele ja esta no .gitignore

# ─────────────────────────────────────────────────────────────────────────────
# AZURE DEVOPS PAT
# ─────────────────────────────────────────────────────────────────────────────
# Como gerar:
#   1. Acesse: https://dev.azure.com/MetLife-Global/_usersSettings/tokens
#   2. New Token → nome: em-dashboard → Organization: MetLife-Global
#   3. Expiration: 90 days
#   4. Scopes (Custom defined):
#      - Code       → Read & Write
#      - Build      → Read
#      - Work Items → Read
#      - Analytics  → Read
#   5. Copie o token — aparece UMA UNICA VEZ
#
AZURE_DEVOPS_PAT=seu_azure_devops_pat_aqui

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB PAT (para o Copilot API — conta filipe-s-lacerda_met)
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANTE: Este PAT e da sua conta GITHUB (filipe-s-lacerda_met),
# separada do Azure DevOps. Isso e esperado e funciona normalmente.
#
# Como gerar:
#   1. Acesse: https://github.com/settings/tokens
#   2. Generate new token (classic)
#   3. Note: copilot-pipeline-metlife
#   4. Expiration: 90 days
#   5. Scopes: marque apenas "copilot"
#   6. Copie o token
#
# Usado por: scripts/get-copilot-token.ps1 e pelo pipeline azure-pipelines-copilot-review.yml
# No pipeline, este PAT fica no Variable Group "copilot-review" no Azure DevOps Library.
#
GITHUB_PAT=seu_github_pat_aqui
